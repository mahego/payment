// ──────────────────────────────────────────────────
// Deluxnet – Prisma Schema  (Auth + Security layer)
// ──────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  COLLECTOR
  TECHNICIAN
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  DEPOSITO
  TARJETA
}

enum CustomerStatus {
  ACTIVO
  SUSPENDIDO
  MOROSO
  CANCELADO
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ServicePlanType {
  PPPOE
  SIMPLE_QUEUE
  HOTSPOT
}

enum OutboxStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

// ─── Auth & IAM ───────────────────────────────────

model User {
  id              String      @id @default(cuid())
  tenantId        String?
  name            String
  email           String      @unique
  phone           String?
  passwordHash    String
  status          UserStatus  @default(ACTIVE)
  role            Role        @default(VIEWER)
  lastLoginAt     DateTime?
  failedAttempts  Int         @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sessions          Session[]
  loginAttempts     LoginAttempt[]
  passwordResets    PasswordResetToken[]
  auditLogs         AuditLog[]
  collectorProfile  CollectorProfile?
  technicianProfile TechnicianProfile?
  payments          Payment[]
  ticketsCreated    Ticket[]             @relation("TicketsCreated")
  ticketsAssigned   Ticket[]             @relation("TicketsAssigned")
  ticketComments    TicketComment[]

  @@index([email, status])
  @@index([tenantId, role, status])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  deviceName       String?
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  userId     String?
  email      String
  ipAddress  String?
  userAgent  String?
  success    Boolean
  reason     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  entityType  String
  entityId    String?
  action      String
  ipAddress   String?
  userAgent   String?
  deviceId    String?
  metadata    Json?
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}

// ─── Collector & Technician profiles ──────────────

model CollectorProfile {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  assignedZone              String?
  cashLimit                 Decimal? @db.Decimal(12, 2)
  canRegisterOfflinePayments Boolean  @default(true)
  active                    Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TechnicianProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  specialization String?
  canRegisterPayments Boolean @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Customers (stub – to be expanded) ────────────

enum MikrotikSuspensionType {
  PPPOE
  QUEUE
  ADDRESS_LIST
}

enum NetworkConnectionType {
  VPN
  PUBLIC_IP
  LAN
  MANUAL
}

enum NetworkRouterStatus {
  PENDING
  ONLINE
  OFFLINE
  ERROR
  DISABLED
}

enum NetworkServiceMode {
  PPPOE
  SIMPLE_QUEUE
  HOTSPOT
  ADDRESS_LIST
}

enum NetworkActionType {
  TEST_CONNECTION
  SUSPEND_CUSTOMER
  REACTIVATE_CUSTOMER
  DISABLE_PPPOE
  ENABLE_PPPOE
  DISABLE_QUEUE
  ENABLE_QUEUE
  DISABLE_HOTSPOT
  ENABLE_HOTSPOT
  ADD_ADDRESS_LIST
  REMOVE_ADDRESS_LIST
}

enum NetworkActionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRYING
}

model Customer {
  id               String          @id @default(cuid())
  firstName        String
  lastName         String
  phone            String?
  email            String?
  addressLine      String
  locality         String?
  municipality     String?
  status           CustomerStatus  @default(ACTIVO)
  pppoeUsername    String?
  pppoePassword    String?
  ipAddress        String?
  currentBalance   Decimal         @default(0) @db.Decimal(12, 2)
  signupDate       DateTime
  billingCutoffDay Int
  mikrotikProfileId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  serviceMode           NetworkServiceMode  @default(PPPOE)
  simpleQueueName       String?
  hotspotUsername       String?
  macAddress            String?
  suspensionAddressList String?             @default("suspended")
  isNetworkSuspended    Boolean             @default(false)
  lastSuspendedAt       DateTime?
  lastReactivatedAt     DateTime?

  mikrotikProfile  MikrotikProfile? @relation(fields: [mikrotikProfileId], references: [id], onDelete: SetNull)
  payments         Payment[]
  networkActions   NetworkAction[]
  zoneId           String?
  planId           String?
  zone             Zone?            @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  plan             ServicePlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  tickets          Ticket[]
}

// ─── Payments (stub – to be expanded) ─────────────

model Payment {
  id              String        @id @default(cuid())
  customerId      String
  createdById     String
  folio           String        @unique
  clientRequestId String        @unique
  method          PaymentMethod
  amount          Decimal       @db.Decimal(12, 2)
  paidAt          DateTime
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([customerId, paidAt])
  @@index([clientRequestId])
}

// ─── Outbox (offline sync) ─────────────────────────

model OutboxEvent {
  id              String       @id @default(cuid())
  deviceId        String
  userId          String
  aggregateType   String
  aggregateId     String
  operation       String
  clientRequestId String       @unique
  payload         Json
  status          OutboxStatus @default(PENDING)
  errorMessage    String?
  attempts        Int          @default(0)
  occurredAt      DateTime
  syncedAt        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, status, occurredAt])
  @@index([aggregateType, aggregateId])
}

// ─── MikroTik Integration ─────────────────────────

model MikrotikProfile {
  id              String                  @id @default(cuid())
  tenantId        String?
  name            String                  @unique
  host            String
  port            Int                     @default(8728)
  username        String
  password        String
  suspensionType  MikrotikSuspensionType  @default(PPPOE)
  pppoeService    String?
  addressListName String?                 @default("suspended")
  active          Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  zoneName              String?
  description           String?
  connectionType        NetworkConnectionType   @default(VPN)
  status                NetworkRouterStatus     @default(PENDING)
  lastSeenAt            DateTime?
  lastConnectionTestAt  DateTime?

  commandLogs     MikrotikCommandLog[]
  customers       Customer[]
  networkActions  NetworkAction[]
}

model MikrotikCommandLog {
  id              String          @id @default(cuid())
  profileId       String
  customerId      String?
  command         String
  payload         Json
  status          String          // "PENDING", "SUCCESS", "FAILED"
  attempts        Int             @default(0)
  errorMessage    String?
  executedAt      DateTime?
  createdAt       DateTime        @default(now())

  profile         MikrotikProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([command, status])
  @@index([createdAt])
}

model NetworkAction {
  id              String              @id @default(cuid())
  profileId       String
  customerId      String?
  actionType      NetworkActionType
  status          NetworkActionStatus @default(PENDING)
  payload         Json?
  errorMessage    String?
  attempts        Int                 @default(0)
  executedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  profile         MikrotikProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  customer        Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([profileId, status])
  @@index([customerId])
}

model Zone {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  billingCutoffDay Int?    // override per-zone cutoff; null = use customer's own
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customers       Customer[]
  plans           ServicePlan[]
}

model ServicePlan {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  speed       String          // e.g. "10M/5M"
  price       Decimal         @db.Decimal(12, 2)
  planType    ServicePlanType @default(PPPOE)
  active      Boolean         @default(true)
  zoneId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  zone        Zone?      @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  customers   Customer[]
}

model Ticket {
  id           String         @id @default(cuid())
  customerId   String
  createdById  String
  assignedToId String?
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy   User            @relation("TicketsCreated", fields: [createdById], references: [id])
  assignedTo  User?           @relation("TicketsAssigned", fields: [assignedToId], references: [id])
  comments    TicketComment[]

  @@index([customerId, status])
  @@index([assignedToId, status])
  @@index([status, priority, createdAt])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
}
