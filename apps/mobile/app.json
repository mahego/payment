{
  "expo": {
    "name": "Deluxnet",
    "slug": "deluxnet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "deluxnet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#2563eb"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "http://127.0.0.1:3001/api/v1"
    }
  }
}
